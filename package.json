{
  "name": "document-ai-flywheel",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Document AI Self-Improvement Flywheel — v1 prototype (S3 build). DAEJOO commercial-invoice anchor; deterministic mock extraction; live SAP AI Core for every agentic step.",
  "scripts": {
    "dev": "concurrently -n web,server -c blue,magenta \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite",
    "dev:server": "tsx --env-file=.env scripts/dev-agent-server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run",
    "evals": "vitest run src/evals",
    "evals:live": "node --env-file=.env node_modules/vitest/vitest.mjs run src/evals/live.test.tsx",
    "observe:push": "node --env-file=.env scripts/push-eval-to-langfuse.mjs"
  },
  "dependencies": {
    "@langfuse/otel": "^5.3.0",
    "@langfuse/tracing": "^5.3.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@ui5/webcomponents": "^2.4.0",
    "@ui5/webcomponents-fiori": "^2.4.0",
    "@ui5/webcomponents-react": "^2.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.0",
    "eslint": "^9.14.0",
    "jsdom": "^29.1.1",
    "pdf-parse": "^2.4.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
