# Copy this file to .env and fill in the values before the workshop.

# FMP_API_KEY — Financial Modeling Prep API key (free tier = 250 calls/day)
# Sign up at https://financialmodelingprep.com

FMP_API_KEY=

# ANTHROPIC_API_KEY — Anthropic API key (separate from Claude Pro / Max subscription)
# If you have Claude Code Max plan, you can skip this and use Max-plan SDK auth instead.

# Get an API key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Langfuse — observability for LLM calls and server-side spans.
# Create a project at https://cloud.langfuse.com (or self-host) and copy the
# public/secret key pair from Settings -> API Keys. Leave blank to disable
# tracing locally; the SDK no-ops when keys are missing.
#
# LANGFUSE_BASE_URL: pick the region that matches the project:
#   EU     -> https://cloud.langfuse.com
#   US     -> https://us.cloud.langfuse.com
#   Japan  -> https://jp.cloud.langfuse.com
#   HIPAA  -> https://hipaa.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
